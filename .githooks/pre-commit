#!/usr/bin/env bash
#
# Q-Gress pre-commit gate. Runs only when Kotlin sources are staged and enforces the FULL gate so
# nobody has to run it by hand:
#   1. ktlintFormat  — auto-fix formatting, then re-stage the staged Kotlin files
#   2. compileKotlinJs + ktlintCheck + detekt + jsNodeTest  — compile, style, complexity, unit tests
# (Config cache keeps this to a few seconds.) Install with:
#     ./gradlew installGitHooks      (sets core.hooksPath to .githooks)
#
# NOTE: step 1 re-stages WHOLE staged files, so prefer staging whole files (git add -A). To bypass in
# an emergency: git commit --no-verify  (don't make a habit of it).

set -euo pipefail

# Only gate Kotlin / Kotlin-script changes.
staged_kotlin="$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.kts?$' || true)"
if [ -z "$staged_kotlin" ]; then
    exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Best-effort: pick up the project toolchain if the committing shell is bare.
if [ -z "${JAVA_HOME:-}" ] && [ -x /usr/lib/jvm/java-21-openjdk-amd64/bin/java ]; then
    export JAVA_HOME="/usr/lib/jvm/java-21-openjdk-amd64"
fi

echo "[pre-commit] ktlintFormat (auto-fix)..."
./gradlew --quiet --console=plain ktlintFormat
# Re-stage any formatting fixes ktlintFormat made to the already-staged files.
echo "$staged_kotlin" | xargs -r git add --

echo "[pre-commit] compile + ktlintCheck + detekt + tests..."
if ! ./gradlew --quiet --console=plain compileKotlinJs ktlintCheck detekt jsNodeTest; then
    echo
    echo "[pre-commit] FAILED. Fix the compile/detekt/test errors above, re-stage, and commit."
    exit 1
fi

echo "[pre-commit] OK."
