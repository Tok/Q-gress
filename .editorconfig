root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{kt,kts}]
ktlint_code_style = intellij_idea
# Cap line length at 140 (a pragmatic middle; 120 is deferred to a future refactor — see PLAN).
# Long JSON/JS-interop string literals that can't wrap are kept on their own line under the cap.
max_line_length = 140
ktlint_standard_max-line-length = enabled
# Existing code leans on a few package wildcard imports; allow them for now.
ktlint_standard_no-wildcard-imports = disabled
# Object-level camelCase "constants" (e.g. Pos.res) are pervasive; detekt's
# naming rules (with baseline) track these instead of churning every call site.
ktlint_standard_property-naming = disabled

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
